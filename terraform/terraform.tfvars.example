# Copy this file to terraform.tfvars and fill in your values.
# Then run: terraform init && terraform apply

aws_region         = "eu-central-2"          # Zurich
domain_name        = "intelliswarm.ai"
environment        = "production"
alert_email        = "your-email@example.com" # Budget alerts go here
monthly_budget_usd = 10                       # Alert at $5, $8, $10
github_token       = ""                       # Optional: for contribution GitHub issues
contact_email      = "your-email@example.com" # Contact form submissions forwarded here (must verify in SES)
